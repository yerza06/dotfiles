[general]
import = [
    "themes/flexoki-dark.toml"
    # "themes/flexoki-light.toml"
]

[window]
padding.x = 10
padding.y = 10
opacity = 0.95
# blur = true


[font]
normal.family = "IosevkaTermNerdFont"
normal.style = "Medium"

bold.family = "IosevkaTermNerdFont"
bold.style = "Bold"

italic.family = "IosevkaTermNerdFont"

italic.style = "italic"

bold_italic.family = "IosevkaTermNerdFont"
bold_italic.style = "Bold Italic"

size = 14


[cursor]
style.shape = "Beam"
style.blinking = "On"

blink_interval = 500
thickness = 0.2
